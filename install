#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$ROOT/crypto"
shopt -s nullglob

# plaintext configs
cp "$ROOT/.zshrc" ~/.zshrc
mkdir -p ~/.config/zed ~/.config/nvim ~/.config/neovide ~/.config/ghostty
cp "$ROOT/.config/zed/settings.json" ~/.config/zed/settings.json
cp -r "$ROOT/.config/nvim/." ~/.config/nvim/
cp -r "$ROOT/.config/neovide/." ~/.config/neovide/
cp -r "$ROOT/.config/ghostty/." ~/.config/ghostty/

password

# skills: plaintext dirs copied, encrypted ones decrypted
dst=~/.config/agents/skills
mkdir -p "$dst"
for d in "$ROOT/skills"/*/; do
  name="$(basename "$d")"
  rm -rf "$dst/$name"
  cp -R "$d" "$dst/$name"
  echo "public: $name"
done
for f in "$ROOT/skills"/*.enc; do
  name="$(basename "$f" .enc)"
  rm -rf "$dst/$name"
  if ! enc -d -in "$f" 2>/dev/null | tar -xzf - -C "$dst"; then
    echo "failed to decrypt $name — wrong password?" >&2; exit 1
  fi
  echo "encrypted: $name"
done

# firefox: restore bookmarks + search shortcuts. needs firefox closed so it
# doesn't clobber the files on quit. bookmarks import once on next launch.
if pgrep -xq firefox; then
  echo "firefox is running — quit it and re-run ./install to restore bookmarks" >&2
elif ffdir="$(ffprofile)"; then
  if [[ -f "$ROOT/firefox/bookmarks.html.enc" ]]; then
    if ! enc -d -in "$ROOT/firefox/bookmarks.html.enc" -out "$ffdir/bookmarks.html" 2>/dev/null; then
      echo "failed to decrypt bookmarks — wrong password?" >&2; exit 1
    fi
    impref='user_pref("browser.places.importBookmarksHTML", true);'
    grep -qsF "$impref" "$ffdir/prefs.js" || printf '%s\n' "$impref" >> "$ffdir/prefs.js"
    echo "firefox: bookmarks (import on next launch)"
  fi
  if [[ -f "$ROOT/firefox/search.json.mozlz4.enc" ]]; then
    if ! enc -d -in "$ROOT/firefox/search.json.mozlz4.enc" -out "$ffdir/search.json.mozlz4" 2>/dev/null; then
      echo "failed to decrypt search shortcuts — wrong password?" >&2; exit 1
    fi
    echo "firefox: search shortcuts"
  fi
  autopref='user_pref("browser.bookmarks.autoExportHTML", true);'
  grep -qsF "$autopref" "$ffdir/user.js" || printf '%s\n' "$autopref" >> "$ffdir/user.js"
else
  echo "firefox: no profile — open firefox once, quit it, re-run ./install" >&2
fi

# private files
while IFS= read -r path; do
  f="$ROOT/private/$path.enc"
  [[ -f "$f" ]] || { echo "missing: $f" >&2; continue; }
  mkdir -p "$(dirname ~/"$path")"
  if ! enc -d -in "$f" -out ~/"$path" 2>/dev/null; then
    echo "failed to decrypt $path — wrong password?" >&2; exit 1
  fi
  chmod 600 ~/"$path" || true
  echo "private: $path"
done < <(private)
