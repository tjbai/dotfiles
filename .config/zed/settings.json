{
  "icon_theme": "Zed (Default)",
  "vim_mode": true,
  "relative_line_numbers": true,
  "base_keymap": "VSCode",
  "ui_font_size": 14,
  "buffer_font_size": 11,
  "theme": "Kanagawa Dragon",
  "show_edit_predictions": false,
  "language_servers": [
    "basedpyright",
    "ty",
    "pyright",
    "metals",
    "ocamllsp",
    "tsgo"
  ],
  "extend_comment_on_newline": false,
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "format_on_save": "off",
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false
  },
  "gutter": {
    "line_numbers": false,
    "code_actions": false,
    "folds": false,
    "min_line_number_digits": 0
  },
  "scrollbar": {
    "show": "never"
  },
  "features": {
    "copilot": false
  },
  "outline_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "diagnostics": {
    "include_warnings": false
  },
  "agent": {
    "enabled": false,
    "button": false
  },
  "chat_panel": {
    "button": "never"
  },
  "notification_panel": {
    "button": false
  },
  "language_models": {
    "copilot_chat": null
  },
  "terminal": {
    "button": false
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false
  },
  "project_panel": {
    "button": false,
    "indent_size": 16
  },
  "preferred_line_length": 160,
  "languages": {
    "Markdown": {
      "soft_wrap": "preferred_line_length",
      "preferred_line_length": 150,
      "remove_trailing_whitespace_on_save": true
    },
    "Python": {
      "remove_trailing_whitespace_on_save": true
    },
    "TypeScript": {
      "language_servers": ["!tsgo", "vtsls", "..."]
    },
    "TSX": {
      "language_servers": ["!tsgo", "vtsls", "..."]
    },
    "JavaScript": {
      "language_servers": ["!tsgo", "vtsls", "..."],
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    }
  },
  "lsp": {
    "pyright": {
      "settings": {
        "python.analysis": {
          "typeCheckingMode": "standard"
        },
        "python": {
          "pythonPath": ".venv/bin/python"
        }
      }
    },
    "tsgo": {
      "initialization_options": {
        "scriptKind": "auto"
      }
    }
  },
  "indent_guides": {
    "enabled": true
  },
  "remove_trailing_whitespace_on_save": false,
  "experimental.theme_overrides": {
    "editor.document_highlight.bracket_background": "#00000000",
    "editor.document_highlight.read_background": "#00000000",
    "editor.document_highlight.write_background": "#00000000"
  },
  "disable_ai": true,
  "diagnostics": {
    "button": false,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 2,
      "min_column": 0,
      "max_severity": "error"
    },
    "cargo": null
  },
  "active_pane_modifiers": {
    "border_size": 0.0,
    "inactive_opacity": 1.0
  },
  "cursor_blink": false
}
